Google_API_KEY=

## This example uses the Google provider, but you can use any provider

## To use other providers, enable the corresponding feature flag e.g. openai
## and add the API key to the .env file

## For example, to use OpenAI
# OpenAI_API_KEY=
## and replace the model in main.rs with e.g. OpenAI::gpt_3_5_turbo()

## other 70+ providers are available see: https://aisdk.rs/docs#model-providers
